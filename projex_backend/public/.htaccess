# Active le moteur de réécriture d'URL (Apache)
RewriteEngine On

# Base du dossier (si ton projet est dans /projex)
RewriteBase /projex/public/

# Si le fichier ou dossier demandé existe vraiment, on le laisse passer
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Sinon, on redirige tout vers index.php
RewriteRule ^ index.php [L]